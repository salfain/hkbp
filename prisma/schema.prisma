generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  JEMAAT
}

// BARU: Status untuk Approval Akun Jemaat
enum StatusAkun {
  PENDING   // Baru mendaftar, belum bisa login
  AKTIF     // Sudah di-ACC Admin, bisa login
  DITOLAK   // Ditolak Admin
}

// BARU: Tipe Kegiatan untuk membedakan alur pendaftaran
enum TipeKegiatan {
  UMUM      // Daftar langsung masuk (cth: Ibadah Minggu)
  KHUSUS    // Butuh ACC Admin (cth: Nikah, Sidi, Baptis, Pindah)
}

// UPDATE: Penyesuaian Status Pendaftaran
enum StatusPendaftaran {
  MENUNGGU_ACC // Khusus kegiatan KHUSUS
  TERDAFTAR    // Sukses (Kegiatan UMUM langsung ke sini, KHUSUS kalau di-ACC)
  DITOLAK      // Jika pendaftaran KHUSUS ditolak
  HADIR        // Saat hari-H diabsen
  TIDAK_HADIR  // Tidak datang
}

enum ChatThreadStatus {
  OPEN
  CLOSED
}

model User {
  id           String      @id @default(cuid()) @db.VarChar(36)
  namaLengkap  String      @db.VarChar(100)
  email        String      @unique @db.VarChar(100)
  password     String      @db.VarChar(255)
  nomorTelepon String?     @db.VarChar(15)
  tanggalLahir DateTime    @db.Timestamp(3)
  alamat       String?     @db.VarChar(255)
  sektor       String?     @db.VarChar(50)
  role         Role        @default(JEMAAT)
  statusAkun   StatusAkun  @default(PENDING) // Default Register adalah PENDING

  createdAt    DateTime    @default(now()) @db.Timestamp(3)
  updatedAt    DateTime    @updatedAt @db.Timestamp(3)

  pendaftaran  Pendaftaran[]
  chatThreads   ChatThread[] @relation("ChatThreadJemaat")
  chatMessages  ChatMessage[] @relation("ChatMessageSender")
}

model Kegiatan {
  id             String        @id @default(cuid()) @db.VarChar(36)
  namaAcara      String        @db.VarChar(150)
  deskripsi      String?       @db.VarChar(255)
  tanggalMulai   DateTime      @db.Timestamp(3)
  tanggalSelesai DateTime?     @db.Timestamp(3)
  lokasi         String?       @db.VarChar(150)
  kuota          Int?
  kategori       String?       @db.VarChar(100)
  tipeKegiatan   TipeKegiatan  @default(UMUM) // Default UMUM
  imageUrl       String?       @db.VarChar(255)
  
  createdAt      DateTime      @default(now()) @db.Timestamp(3)
  updatedAt      DateTime      @updatedAt @db.Timestamp(3)

  pendaftaran    Pendaftaran[]
}

model Pendaftaran {
  id          String            @id @default(cuid()) @db.VarChar(36)
  userId      String            @db.VarChar(36)
  kegiatanId  String            @db.VarChar(36)
  waktuDaftar DateTime          @default(now()) @db.Timestamp(3)
  status      StatusPendaftaran @default(TERDAFTAR)
  catatan     String?           @db.VarChar(255) // Untuk pesan tambahan dari jemaat (misal: "Nama Pasangan: Budi & Ani")
  formulirData Json?            @db.JsonB
  waktuHadir  DateTime?         @db.Timestamp(3)

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  kegiatan    Kegiatan          @relation(fields: [kegiatanId], references: [id], onDelete: Cascade)

  @@unique([userId, kegiatanId])
}

model ChatThread {
  id            String           @id @default(cuid()) @db.VarChar(36)
  jemaatId      String           @unique @db.VarChar(36)
  status        ChatThreadStatus @default(OPEN)
  lastMessageAt DateTime         @default(now()) @db.Timestamp(3)
  createdAt     DateTime         @default(now()) @db.Timestamp(3)
  updatedAt     DateTime         @updatedAt @db.Timestamp(3)

  jemaat        User             @relation("ChatThreadJemaat", fields: [jemaatId], references: [id], onDelete: Cascade)
  messages      ChatMessage[]

  @@index([status])
  @@index([lastMessageAt])
}

model ChatMessage {
  id        String     @id @default(cuid()) @db.VarChar(36)
  threadId  String     @db.VarChar(36)
  senderId  String     @db.VarChar(36)
  body      String     @db.VarChar(255)
  createdAt DateTime   @default(now()) @db.Timestamp(3)

  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User       @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([senderId])
}
